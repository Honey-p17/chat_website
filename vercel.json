{
  "services": {
    "frontend": {
      "root": "frontend"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "src/server.ts"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/backend/api/:path*"
    },
    {
      "source": "/health",
      "destination": "/backend/health"
    },
    {
      "source": "/:path*",
      "destination": "/frontend/:path*"
    }
  ]
}
